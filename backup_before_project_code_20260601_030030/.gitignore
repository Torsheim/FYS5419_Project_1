# Data/results that can become large
# Keep .gitkeep files so the directory structure remains visible.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
results/figures/*
!results/figures/.gitkeep
results/tables/*
!results/tables/.gitkeep

